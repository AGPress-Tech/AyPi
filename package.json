{
  "name": "aypi",
  "version": "1.3.0",
  "description": "Software AyPi per gestione applicativi AGPress",
  "main": "dist-ts/main.js",
  "scripts": {
    "start": "npm run build:ts && electron .",
    "start:bluearchive": "npm run build:ts && electron . --bluearchive-preview",
    "preview:bluearchive": "electron . --bluearchive-preview",
    "build:ts": "node tools\\build-ts.js",
    "build:backend": "npx tsc -p backend\\tsconfig.json",
    "start:backend": "set AYPI_BACKEND_PROFILE=dev&& npm run build:backend && node backend-dist\\server.js",
    "build:backend:tray": "npx tsc -p tsconfig.backend-app.json",
    "start:backend:tray": "set AYPI_BACKEND_PROFILE=dev&& npm run build:backend && npm run build:backend:tray && electron dist-backend-app\\main.js",
    "smoke:backend:port-lock": "npm run build:backend && node tools\\smoke-backend-port-lock.js",
    "smoke:bluearchive:catalog": "set ELECTRON_RUN_AS_NODE=&& electron tools\\smoke-bluearchive-catalog-layout.js",
    "dist:backend": "npm run build:backend && npm run build:backend:tray && electron-builder --config electron-builder.backend.json",
    "build:dir": "npm run build:ts && electron-builder --dir",
    "build": "npm run build:ts && electron-builder",
    "release": "npm run build:ts && electron-builder --publish always"
  },
  "author": "Ayrton Pizzi",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.13.4",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@network-utils/arp-lookup": "^2.1.0",
    "ajv": "^6.12.6",
    "axios": "^1.13.2",
    "bwip-js": "^4.8.0",
    "chart.js": "^4.5.1",
    "dhtmlx-gantt": "*",
    "electron-log": "^5.3.1",
    "electron-prompt": "^1.7.0",
    "electron-updater": "^6.3.9",
    "hash-wasm": "^4.12.0",
    "nodemailer": "^7.0.12",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "sql.js": "^1.14.1",
    "update-electron-app": "^3.1.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.Agpress.AyPi",
    "productName": "AyPi",
    "files": [
      "dist-ts/**/*",
      "package.json",
      "!**/*.ts",
      "!**/*.map",
      "!dist-backend/**/*",
      "!dist-backend-app/**/*",
      "!backend/**/*",
      "!backend-dist/**/*",
      "!src/**/*",
      "!docs/**/*",
      "!tools/**/*",
      "!.tmp-backend-test/**/*",
      "!cards_ts/**/*",
      "!types/**/*",
      "!*.log",
      "!tsconfig*.json",
      "!electron-builder.backend.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "AGPress-Tech",
        "repo": "AyPi",
        "releaseType": "release",
        "private": false
      }
    ],
    "mac": {
      "icon": "assets/app-icon.icns"
    },
    "win": {
      "icon": "assets/app-icon.ico",
      "target": "nsis",
      "sign": false
    },
    "linux": {
      "icon": "assets/app-icon.png"
    },
    "directories": {
      "output": "dist"
    }
  }
}
