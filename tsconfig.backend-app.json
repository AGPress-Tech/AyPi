{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": "src/backend-app",
    "outDir": "dist-backend-app"
  },
  "include": ["src/backend-app/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-ts", "dist-backend-app"]
}
